# ============================================================
# OneShop Data Platform — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- Postgres (OLTP + pgvector) ---
POSTGRES_USER=postgresuser
POSTGRES_PASSWORD=postgrespw
POSTGRES_DB=oneshop
POSTGRES_PORT=5432

# --- Postgres ETL User (least-privilege) ---
ETL_USER=etluser
ETL_PASSWORD=etlpassword

# --- MinIO (S3-compatible Object Storage) ---
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=password
MINIO_ENDPOINT=http://minio:9000
AWS_REGION=us-east-1

# --- Kafka (KRaft mode) ---
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk

# --- Iceberg REST Catalog ---
ICEBERG_CATALOG_URI=http://iceberg-catalog:8181
ICEBERG_WAREHOUSE=s3://warehouse/

# --- Trino ---
TRINO_USER=test
TRINO_PASSWORD=password
TRINO_KEYSTORE_PASSWORD=trino123

# --- Superset ---
SUPERSET_SECRET_KEY=mysecretkey
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=admin
SUPERSET_ADMIN_EMAIL=admin@example.com

# --- ClickHouse ---
CLICKHOUSE_PASSWORD=mysecret

# --- Airflow ---
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW__CORE__FERNET_KEY=46BKJoQYlPPOexq0OhDZnIlNepKFf87WFwLbfzqDDho=

# --- Flask Recommendation API ---
FLASK_PORT=5050

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# --- Schema Registry ---
SCHEMA_REGISTRY_PORT=8081
